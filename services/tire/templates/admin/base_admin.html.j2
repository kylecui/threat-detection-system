<!DOCTYPE html>
<html lang="{{ lang|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ t('admin.title') }}{% endblock %} — TIRE</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { min-height: 100vh; }
        .sidebar {
            width: 250px;
            min-height: 100vh;
            background-color: #212529;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
            padding-top: 0;
            transition: margin-left 0.3s;
        }
        .sidebar .nav-link {
            color: rgba(255,255,255,.75);
            padding: 0.75rem 1.25rem;
            border-left: 3px solid transparent;
        }
        .sidebar .nav-link:hover {
            color: #fff;
            background-color: rgba(255,255,255,.05);
        }
        .sidebar .nav-link.active {
            color: #fff;
            background-color: rgba(13,110,253,.15);
            border-left-color: #0d6efd;
        }
        .sidebar .sidebar-brand {
            padding: 1rem 1.25rem;
            color: #fff;
            font-size: 1.15rem;
            font-weight: 600;
            border-bottom: 1px solid rgba(255,255,255,.1);
        }
        .sidebar .sidebar-divider {
            border-top: 1px solid rgba(255,255,255,.1);
            margin: 0.5rem 0;
        }
        .sidebar .nav-link.text-muted-light {
            color: rgba(255,255,255,.4);
            font-size: 0.85rem;
        }
        .main-content {
            margin-left: 250px;
            min-height: 100vh;
        }
        .top-bar {
            background: #fff;
            border-bottom: 1px solid #dee2e6;
            padding: 0.75rem 1.5rem;
        }
        .content-area {
            padding: 1.5rem;
        }
        @media (max-width: 768px) {
            .sidebar { margin-left: -250px; }
            .sidebar.show { margin-left: 0; }
            .main-content { margin-left: 0; }
        }
    </style>
    {% block extra_head %}{% endblock %}
</head>
<body>
    <!-- Sidebar -->
    <nav class="sidebar d-flex flex-column" id="sidebar">
        <div class="sidebar-brand">
            🛡️ TIRE {{ t('admin.title') }}
        </div>
        <ul class="nav flex-column flex-grow-1 mt-2">
            <li class="nav-item">
                <a class="nav-link {% block nav_dashboard %}{% endblock %}" href="{{ root_path }}/admin/">
                    📊 {{ t('admin.dashboard') }}
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% block nav_plugins %}{% endblock %}" href="{{ root_path }}/admin/plugins">
                    🔌 {{ t('admin.plugins') }}
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% block nav_llm %}{% endblock %}" href="{{ root_path }}/admin/settings/llm">
                    🤖 {{ t('admin.llm_settings') }}
                </a>
            </li>
            {% if user.is_admin %}
            <li class="nav-item">
                <a class="nav-link {% block nav_usage %}{% endblock %}" href="{{ root_path }}/admin/usage">
                    📈 {{ t('admin.api_usage') }}
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% block nav_api_keys %}{% endblock %}" href="{{ root_path }}/admin/settings/api-keys">
                    🔑 {{ t('admin.shared_api_keys') }}
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% block nav_groups %}{% endblock %}" href="{{ root_path }}/admin/groups">
                    🧩 {{ t('admin.policy_groups') }}
                </a>
            </li>
            {% endif %}
            <li class="nav-item">
                <a class="nav-link {% block nav_my_api_keys %}{% endblock %}" href="{{ root_path }}/admin/settings/my-api-keys">
                    🗝️ {{ t('admin.my_api_keys') }}
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% block nav_profile %}{% endblock %}" href="{{ root_path }}/admin/profile">
                    👤 {{ t('admin.profile') }}
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% block nav_logs %}{% endblock %}" href="{{ root_path }}/admin/logs">
                    📋 {{ t('admin.logs') }}
                </a>
            </li>
            {% if user.is_admin %}
            <li class="nav-item">
                <a class="nav-link {% block nav_users %}{% endblock %}" href="{{ root_path }}/admin/users">
                    👥 {{ t('admin.users') }}
                </a>
            </li>
            {% endif %}
        </ul>
        <div class="sidebar-divider"></div>
        <ul class="nav flex-column mb-3">
            <li class="nav-item">
                <a class="nav-link text-muted-light" href="{{ root_path }}/">
                    ← {{ t('admin.back_to_tire') }}
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-muted-light" href="{{ root_path }}/admin/logout">
                    {{ t('admin.logout') }}
                </a>
            </li>
        </ul>
    </nav>

    <!-- Main content -->
    <div class="main-content">
        <div class="top-bar d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <button class="btn btn-sm btn-outline-secondary d-md-none me-3" onclick="document.getElementById('sidebar').classList.toggle('show')">
                    ☰
                </button>
                <h5 class="mb-0">{% block page_title %}{{ t('admin.dashboard') }}{% endblock %}</h5>
            </div>
            <div class="d-flex align-items-center">
                <span class="text-muted me-3">{{ user.display_name }}</span>
                <a href="#" onclick="switchLang('en'); return false;" class="text-decoration-none {% if lang|default('en') != 'zh' %}fw-bold text-primary{% else %}text-muted{% endif %}">EN</a>
                <span class="text-muted mx-1">|</span>
                <a href="#" onclick="switchLang('zh'); return false;" class="text-decoration-none {% if lang|default('en') == 'zh' %}fw-bold text-primary{% else %}text-muted{% endif %}">中文</a>
            </div>
        </div>
        <div class="content-area">
            {% block content %}{% endblock %}
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    function switchLang(lang) {
        var url = window.location.pathname;
        var params = new URLSearchParams(window.location.search);
        params.set('lang', lang);
        window.location.href = url + '?' + params.toString();
    }
    </script>
    {% block extra_js %}{% endblock %}
</body>
</html>
