{% extends "admin/base_admin.html.j2" %}

{% block title %}{{ t('admin.configure') }} — {{ plugin_info.display_name }}{% endblock %}
{% block nav_plugins %}active{% endblock %}
{% block page_title %}{{ t('admin.configure') }} — {{ plugin_info.display_name }}{% endblock %}

{% block content %}
{% if msg %}
<div class="alert alert-info alert-dismissible fade show" role="alert">
    {{ msg }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

<div class="mb-4">
    <a href="{{ root_path }}/admin/plugins" class="text-decoration-none">← {{ t('admin.plugins') }}</a>
</div>

<div class="card mb-4">
    <div class="card-header">
        <strong>{{ plugin_info.display_name }}</strong>
        <span class="badge bg-secondary ms-2">v{{ plugin_info.version }}</span>
    </div>
    <div class="card-body">
        <p class="text-muted mb-0">{{ plugin_info.description }}</p>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" action="{{ root_path }}/admin/plugins/{{ plugin_name }}/config">
            <div class="mb-3">
                <label for="priority" class="form-label">{{ t('admin.priority') }}</label>
                <input type="number" class="form-control" id="priority" name="priority"
                       value="{{ plugin_cfg.priority|default(50) }}" min="0" max="100" style="max-width: 150px;">
            </div>

            {% if plugin_info.api_key_env_var %}
            <div class="mb-3">
                <label class="form-label">{{ t('admin.api_key_env') }}</label>
                <input type="text" class="form-control" value="{{ plugin_info.api_key_env_var }}" readonly
                       style="max-width: 400px; background-color: #e9ecef;">
            </div>
            {% endif %}

            <div class="mb-3">
                <label for="config_json" class="form-label">{{ t('admin.config_json') }}</label>
                <textarea class="form-control" id="config_json" name="config_json"
                          rows="10" style="font-family: monospace; font-size: 0.9rem;">{{ config_json }}</textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">{{ t('admin.save') }}</button>
                <a href="{{ root_path }}/admin/plugins" class="btn btn-outline-secondary">{{ t('admin.cancel') }}</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
