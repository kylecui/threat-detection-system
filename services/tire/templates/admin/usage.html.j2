{% extends "admin/base_admin.html.j2" %}

{% block title %}{{ t('admin.api_usage') }}{% endblock %}
{% block nav_usage %}active{% endblock %}
{% block page_title %}{{ t('admin.api_usage') }}{% endblock %}

{% block content %}
<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">📡 {{ t('admin.plugin_api_calls_30d') }}</h6>
                <h3 class="card-title">{{ usage_snapshot.plugin_overview.calls }}</h3>
                <p class="card-text text-muted mb-1">{{ t('admin.success_rate_label') }}: {{ '%.0f'|format((usage_snapshot.plugin_overview.success_rate or 0) * 100) }}%</p>
                <small class="text-muted">{{ t('admin.avg_latency_ms') }}: {{ usage_snapshot.plugin_overview.avg_latency_ms if usage_snapshot.plugin_overview.avg_latency_ms is not none else '—' }}</small>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">🤖 {{ t('admin.llm_calls_30d') }}</h6>
                <h3 class="card-title">{{ usage_snapshot.llm_overview.calls }}</h3>
                <p class="card-text text-muted mb-1">{{ t('admin.success_rate_label') }}: {{ '%.0f'|format((usage_snapshot.llm_overview.success_rate or 0) * 100) }}%</p>
                <small class="text-muted">{{ t('admin.total_tokens') }}: {{ usage_snapshot.llm_overview.total_tokens }}</small>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h6 class="mb-0">{{ t('admin.plugin_api_calls_30d') }}</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>{{ t('admin.plugin_name') }}</th>
                        <th>{{ t('admin.calls') }}</th>
                        <th>{{ t('admin.success_rate_label') }}</th>
                        <th>{{ t('admin.avg_latency_ms') }}</th>
                        <th>{{ t('admin.shared_api_keys') }}</th>
                        <th>{{ t('admin.my_api_keys') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in usage_snapshot.plugin_summary %}
                    <tr>
                        <td>{{ item.plugin_name }}</td>
                        <td>{{ item.calls }}</td>
                        <td>{{ '%.0f'|format((item.success_rate or 0) * 100) }}%</td>
                        <td>{{ item.avg_latency_ms if item.avg_latency_ms is not none else '—' }}</td>
                        <td>{{ item.shared_calls }}</td>
                        <td>{{ item.personal_calls }}</td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">{{ t('admin.no_usage_yet') }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h6 class="mb-0">{{ t('admin.llm_calls_30d') }}</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>{{ t('admin.source') }}</th>
                        <th>{{ t('admin.model') }}</th>
                        <th>{{ t('admin.calls') }}</th>
                        <th>{{ t('admin.total_tokens') }}</th>
                        <th>{{ t('admin.success_rate_label') }}</th>
                        <th>{{ t('admin.avg_latency_ms') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in usage_snapshot.llm_summary %}
                    <tr>
                        <td>{{ item.source }}</td>
                        <td>{{ item.model }}</td>
                        <td>{{ item.calls }}</td>
                        <td>{{ item.total_tokens }}</td>
                        <td>{{ '%.0f'|format((item.success_rate or 0) * 100) }}%</td>
                        <td>{{ item.avg_latency_ms if item.avg_latency_ms is not none else '—' }}</td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">{{ t('admin.no_usage_yet') }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
