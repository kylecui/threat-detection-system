<!DOCTYPE html>
<html lang="{{ lang|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ t('admin.login') }} — TIRE</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
    </style>
</head>
<body>
    <div class="position-absolute top-0 end-0 p-3">
        <a href="#" onclick="switchLang('en'); return false;" class="text-decoration-none {% if lang|default('en') != 'zh' %}fw-bold text-primary{% else %}text-muted{% endif %}">EN</a>
        <span class="text-muted mx-1">|</span>
        <a href="#" onclick="switchLang('zh'); return false;" class="text-decoration-none {% if lang|default('en') == 'zh' %}fw-bold text-primary{% else %}text-muted{% endif %}">中文</a>
    </div>

    <div class="container d-flex align-items-center justify-content-center flex-grow-1">
        <div style="width: 100%; max-width: 400px;">
            <div class="text-center mb-4">
                <h2 class="fw-bold">🛡️ TIRE</h2>
                <p class="text-muted small">{{ t('app.title') }}</p>
            </div>
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    {% if error %}
                    <div class="alert alert-danger py-2">{{ error }}</div>
                    {% endif %}
                    <form method="post" action="{{ root_path }}/admin/login">
                        <input type="hidden" name="next_url" value="{{ next_url|default('') }}">
                        <div class="mb-3">
                            <label for="username" class="form-label">{{ t('admin.username') }}</label>
                            <input type="text" class="form-control" id="username" name="username" required autofocus>
                        </div>
                        <div class="mb-3">
                            <label for="password" class="form-label">{{ t('admin.password') }}</label>
                            <input type="password" class="form-control" id="password" name="password" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">{{ t('admin.login_submit') }}</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
    function switchLang(lang) {
        var url = window.location.pathname;
        var params = new URLSearchParams(window.location.search);
        params.set('lang', lang);
        window.location.href = url + '?' + params.toString();
    }
    </script>
</body>
</html>
