{% extends "admin/base_admin.html.j2" %}

{% block title %}{{ t('admin.profile') }}{% endblock %}
{% block nav_profile %}active{% endblock %}
{% block page_title %}{{ t('admin.profile') }}{% endblock %}

{% block content %}
{% if msg %}
<div class="alert {{ 'alert-danger' if 'incorrect' in msg|lower or 'do not match' in msg|lower or 'too short' in msg|lower else 'alert-success' }} alert-dismissible fade show" role="alert">
    {{ msg }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

<div class="row g-4">
    <!-- Profile Info -->
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">{{ t('admin.profile') }}</h6>
            </div>
            <div class="card-body">
                <form method="post" action="{{ root_path }}/admin/profile">
                    <div class="mb-3">
                        <label class="form-label">{{ t('admin.username') }}</label>
                        <input type="text" class="form-control" value="{{ user.username }}" readonly
                               style="background-color: #e9ecef;">
                    </div>
                    <div class="mb-3">
                        <label for="display_name" class="form-label">{{ t('admin.display_name') }}</label>
                        <input type="text" class="form-control" id="display_name" name="display_name"
                               value="{{ user.display_name }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ t('admin.role') }}</label>
                        <input type="text" class="form-control"
                               value="{{ t('admin.admin') if user.is_admin else t('admin.user_role') }}" readonly
                               style="background-color: #e9ecef;">
                    </div>
                    <button type="submit" class="btn btn-primary">{{ t('admin.update_profile') }}</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Change Password -->
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">{{ t('admin.change_password') }}</h6>
            </div>
            <div class="card-body">
                <form method="post" action="{{ root_path }}/admin/profile/password">
                    <div class="mb-3">
                        <label for="current_password" class="form-label">{{ t('admin.current_password') }}</label>
                        <input type="password" class="form-control" id="current_password" name="current_password" required>
                    </div>
                    <div class="mb-3">
                        <label for="new_password" class="form-label">{{ t('admin.new_password') }}</label>
                        <input type="password" class="form-control" id="new_password" name="new_password" required>
                    </div>
                    <div class="mb-3">
                        <label for="confirm_password" class="form-label">{{ t('admin.confirm_password') }}</label>
                        <input type="password" class="form-control" id="confirm_password" name="confirm_password" required>
                    </div>
                    <button type="submit" class="btn btn-warning">{{ t('admin.change_password') }}</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">{{ t('admin.api_usage') }} · 30d</h6>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-md-6">
                        <h6 class="text-muted">{{ t('admin.plugin_api_calls_30d') }}</h6>
                        <div class="fs-4">{{ usage_snapshot.plugin_overview.calls if usage_snapshot else 0 }}</div>
                        <small class="text-muted">{{ t('admin.success_rate_label') }}: {{ '%.0f'|format(((usage_snapshot.plugin_overview.success_rate if usage_snapshot else 0) or 0) * 100) }}%</small>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted">{{ t('admin.llm_calls_30d') }}</h6>
                        <div class="fs-4">{{ usage_snapshot.llm_overview.calls if usage_snapshot else 0 }}</div>
                        <small class="text-muted">{{ t('admin.total_tokens') }}: {{ usage_snapshot.llm_overview.total_tokens if usage_snapshot else 0 }}</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
