<!DOCTYPE html>
<html lang="{{ lang|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ t('dashboard.compare_reports') }} — TIRE</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        iframe.report-frame {
            width: 100%;
            height: 85vh;
            border: 1px solid #dee2e6;
            border-radius: 0.5rem;
            background: #fff;
        }
    </style>
</head>
<body class="bg-light">
    <div class="container-fluid py-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h1 class="h4 mb-1">{{ t('dashboard.compare_reports') }}</h1>
                <p class="text-muted mb-0">{{ t('dashboard.compare_reports_hint') }}</p>
            </div>
            <a href="{{ root_path }}/?lang={{ lang|default('en') }}" class="btn btn-outline-secondary">{{ t('compare.back_to_dashboard') }}</a>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <form method="get" action="{{ root_path }}/reports/compare" class="row g-3 align-items-end">
                    <input type="hidden" name="lang" value="{{ lang|default('en') }}">
                    <div class="col-md-6">
                        <label for="report_a" class="form-label">{{ t('dashboard.left_report') }}</label>
                        <select class="form-select" id="report_a" name="report_a">
                            <option value="">{{ t('dashboard.select_report') }}</option>
                            {% for item in report_history %}
                            <option value="{{ item.id }}" {% if report_a == item.id %}selected{% endif %}>#{{ item.id }} — {{ item.generated_at }} — {{ item.lang }} — {{ 'LLM' if item.llm_enhanced else t('dashboard.template') }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label for="report_b" class="form-label">{{ t('dashboard.right_report') }}</label>
                        <select class="form-select" id="report_b" name="report_b">
                            <option value="">{{ t('dashboard.select_report') }}</option>
                            {% for item in report_history %}
                            <option value="{{ item.id }}" {% if report_b == item.id %}selected{% endif %}>#{{ item.id }} — {{ item.generated_at }} — {{ item.lang }} — {{ 'LLM' if item.llm_enhanced else t('dashboard.template') }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">{{ t('dashboard.compare_reports') }}</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="row g-3">
            {% for report in reports %}
            <div class="col-lg-6">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <div class="fw-semibold">{{ report.ip }}</div>
                        <small class="text-muted">#{{ report.id }} · {{ report.generated_at }} · {{ report.lang }} · {{ 'LLM' if report.llm_enhanced else t('dashboard.template') }}</small>
                    </div>
                </div>
                <iframe class="report-frame" src="{{ root_path }}/reports/view/{{ report.id }}"></iframe>
            </div>
            {% endfor %}
            {% if not reports %}
            <div class="col-12">
                <div class="alert alert-info mb-0">{{ t('dashboard.no_reports_selected') }}</div>
            </div>
            {% endif %}
        </div>
    </div>
</body>
</html>
