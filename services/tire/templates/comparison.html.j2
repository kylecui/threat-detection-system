<!DOCTYPE html>
<html lang="{{ lang|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ t('compare.title') }} - {{ t('app.title') }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .score-delta-up { color: #dc3545; font-weight: bold; }
        .score-delta-down { color: #28a745; font-weight: bold; }
        .score-delta-same { color: #6c757d; font-weight: bold; }
        .score-big { font-size: 2.5rem; font-weight: 700; }
        .badge-low { background-color: #28a745; }
        .badge-medium { background-color: #fd7e14; }
        .badge-high { background-color: #dc3545; }
        .badge-critical { background-color: #721c24; }
        .badge-inconclusive { background-color: #6c757d; }
        .diff-added { background-color: rgba(40, 167, 69, 0.1); }
        .diff-removed { background-color: rgba(220, 53, 69, 0.1); }
        .diff-changed { background-color: rgba(255, 193, 7, 0.1); }
        .timeline-section, .diff-section, .diff-results { display: none; }
    </style>
</head>
<body class="bg-light">
    <div class="container py-4">
        <div class="row">
            <div class="col-12">
                <!-- Header Card -->
                <div class="card shadow mb-4">
                    <div class="card-header bg-primary text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h1 class="h4 mb-0">{{ t('compare.title') }}</h1>
                            <div class="d-flex align-items-center">
                                {% if user %}
                                <span class="text-white-50 me-2">{{ user.display_name }}</span>
                                <a href="{{ root_path }}/admin/" class="btn btn-sm btn-outline-light me-2">{{ t('admin.title') }}</a>
                                <a href="{{ root_path }}/admin/logout" class="btn btn-sm btn-outline-light me-2">{{ t('admin.logout') }}</a>
                                {% endif %}
                                <a href="#" onclick="switchLang('en'); return false;" class="text-white text-decoration-none {% if lang|default('en') != 'zh' %}fw-bold{% endif %}">EN</a>
                                <span class="text-white mx-1">|</span>
                                <a href="#" onclick="switchLang('zh'); return false;" class="text-white text-decoration-none {% if lang|default('en') == 'zh' %}fw-bold{% endif %}">中文</a>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <!-- IP Input Form -->
                        <div class="row justify-content-center">
                            <div class="col-md-8 col-lg-6">
                                <label class="form-label">{{ t('compare.enter_ip') }}</label>
                                <div class="input-group">
                                    <input type="text" class="form-control" id="compareIp"
                                           value="{{ ip }}" placeholder="e.g., 8.8.8.8"
                                           pattern="^(\d{1,3}\.){3}\d{1,3}$">
                                    <button class="btn btn-primary" type="button" id="loadBtn" onclick="loadHistory()">
                                        {{ t('compare.load') }}
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Loading Spinner -->
                        <div class="text-center mt-4 d-none" id="loadingSpinner">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>

                        <!-- Error Alert -->
                        <div class="alert alert-warning mt-4 d-none" id="errorAlert"></div>
                    </div>
                </div>

                <!-- Timeline Section -->
                <div class="card shadow mb-4 timeline-section" id="timelineSection">
                    <div class="card-header">
                        <h5 class="mb-0">{{ t('compare.timeline_title') }}</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="timelineChart" height="100"></canvas>
                    </div>
                </div>

                <!-- Diff Section -->
                <div class="card shadow mb-4 diff-section" id="diffSection">
                    <div class="card-header">
                        <h5 class="mb-0">{{ t('compare.diff_title') }}</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">{{ t('compare.select_snapshots') }}</p>
                        <div class="row g-3 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label">{{ t('compare.snapshot_a') }}</label>
                                <select class="form-select" id="snapshotA"></select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">{{ t('compare.snapshot_b') }}</label>
                                <select class="form-select" id="snapshotB"></select>
                            </div>
                            <div class="col-md-4">
                                <button class="btn btn-primary w-100" onclick="compareDiff()">
                                    {{ t('compare.compare_btn') }}
                                </button>
                            </div>
                        </div>

                        <!-- Diff Loading -->
                        <div class="text-center mt-4 d-none" id="diffLoading">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>

                        <!-- Diff Results -->
                        <div class="diff-results mt-4" id="diffResults">
                            <!-- Score Change -->
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <div class="card text-center">
                                        <div class="card-body">
                                            <h6 class="card-subtitle mb-2 text-muted">{{ t('compare.score_change') }}</h6>
                                            <div class="score-big" id="scoreDelta"></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card text-center">
                                        <div class="card-body">
                                            <h6 class="card-subtitle mb-2 text-muted">{{ t('compare.level_change') }}</h6>
                                            <div class="mt-2" id="levelChange"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Evidence Diff Table -->
                            <div class="card mb-4" id="evidenceDiffCard">
                                <div class="card-header">
                                    <h6 class="mb-0">{{ t('compare.evidence_added') }} / {{ t('compare.evidence_removed') }} / {{ t('compare.evidence_changed') }}</h6>
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-sm mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Status</th>
                                                    <th>Source</th>
                                                    <th>Title</th>
                                                    <th>Severity</th>
                                                    <th>Score Impact</th>
                                                </tr>
                                            </thead>
                                            <tbody id="evidenceDiffBody"></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <!-- Source Diff -->
                            <div class="card" id="sourceDiffCard">
                                <div class="card-header">
                                    <h6 class="mb-0">{{ t('compare.source_diff') }}</h6>
                                </div>
                                <div class="card-body">
                                    <div id="sourceDiffContent"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Back Link -->
                <div class="text-center mb-4">
                    <a href="{{ root_path }}/?lang={{ lang|default('en') }}" class="text-decoration-none">
                        &larr; {{ t('compare.back_to_dashboard') }}
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    var rootPath = '{{ root_path }}';
    var currentLang = '{{ lang|default("en") }}';
    var chartInstance = null;
    var timelineData = null;

    function switchLang(lang) {
        var ip = document.getElementById('compareIp').value.trim();
        var url = rootPath + '/compare?lang=' + lang;
        if (ip) url += '&ip=' + encodeURIComponent(ip);
        window.location.href = url;
    }

    function showError(msg) {
        var el = document.getElementById('errorAlert');
        el.textContent = msg;
        el.classList.remove('d-none');
    }

    function hideError() {
        document.getElementById('errorAlert').classList.add('d-none');
    }

    function setLoading(show) {
        var el = document.getElementById('loadingSpinner');
        if (show) el.classList.remove('d-none');
        else el.classList.add('d-none');
    }

    function getLevelColor(level) {
        switch ((level || '').toLowerCase()) {
            case 'low': return '#28a745';
            case 'medium': return '#fd7e14';
            case 'high': return '#dc3545';
            case 'critical': return '#721c24';
            default: return '#6c757d';
        }
    }

    function getLevelBadgeClass(level) {
        switch ((level || '').toLowerCase()) {
            case 'low': return 'badge-low';
            case 'medium': return 'badge-medium';
            case 'high': return 'badge-high';
            case 'critical': return 'badge-critical';
            default: return 'badge-inconclusive';
        }
    }

    function formatDate(isoStr) {
        if (!isoStr) return '';
        var d = new Date(isoStr);
        return d.toLocaleString(currentLang === 'zh' ? 'zh-CN' : 'en-US', {
            year: 'numeric', month: 'short', day: 'numeric',
            hour: '2-digit', minute: '2-digit'
        });
    }

    async function loadHistory() {
        var ip = document.getElementById('compareIp').value.trim();
        if (!ip) return;

        hideError();
        setLoading(true);
        document.getElementById('timelineSection').style.display = 'none';
        document.getElementById('diffSection').style.display = 'none';
        document.getElementById('diffResults').style.display = 'none';

        try {
            var resp = await fetch(rootPath + '/api/v1/results/' + encodeURIComponent(ip) + '/compare');
            if (!resp.ok) {
                var err = await resp.json().catch(function() { return {}; });
                showError(err.detail || '{{ t("compare.no_history") }}');
                setLoading(false);
                return;
            }

            var data = await resp.json();
            timelineData = data;

            if (!data.timeline || data.timeline.length === 0) {
                showError('{{ t("compare.no_history") }}');
                setLoading(false);
                return;
            }

            renderTimeline(data);
            populateSnapshotSelectors(data.timeline);

            document.getElementById('timelineSection').style.display = 'block';
            if (data.timeline.length >= 2) {
                document.getElementById('diffSection').style.display = 'block';
            }
        } catch (e) {
            showError(e.message || '{{ t("compare.no_data") }}');
        } finally {
            setLoading(false);
        }
    }

    function renderTimeline(data) {
        var ctx = document.getElementById('timelineChart').getContext('2d');

        if (chartInstance) {
            chartInstance.destroy();
            chartInstance = null;
        }

        var labels = data.timeline.map(function(s) { return formatDate(s.queried_at); });
        var scores = data.timeline.map(function(s) { return s.final_score; });
        var colors = data.timeline.map(function(s) { return getLevelColor(s.level); });

        chartInstance = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: '{{ t("compare.threat_score") }}',
                    data: scores,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    tension: 0.3,
                    fill: true,
                    pointBackgroundColor: colors,
                    pointBorderColor: colors,
                    pointRadius: 6,
                    pointHoverRadius: 9
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        min: 0,
                        max: 100,
                        title: { display: true, text: '{{ t("compare.threat_score") }}' }
                    },
                    x: {
                        title: { display: true, text: '{{ t("compare.queried_at") }}' }
                    }
                },
                plugins: {
                    tooltip: {
                        callbacks: {
                            afterLabel: function(ctx) {
                                var item = data.timeline[ctx.dataIndex];
                                return item.level + (item.is_archived ? ' ({{ t("compare.archived") }})' : '');
                            }
                        }
                    }
                }
            }
        });
    }

    function populateSnapshotSelectors(timeline) {
        var selA = document.getElementById('snapshotA');
        var selB = document.getElementById('snapshotB');
        selA.innerHTML = '';
        selB.innerHTML = '';

        timeline.forEach(function(s) {
            var label = formatDate(s.queried_at) + ' — Score: ' + s.final_score + ' (' + s.level + ')';
            if (s.is_archived) label += ' [{{ t("compare.archived") }}]';

            var optA = document.createElement('option');
            optA.value = s.id;
            optA.textContent = label;
            selA.appendChild(optA);

            var optB = document.createElement('option');
            optB.value = s.id;
            optB.textContent = label;
            selB.appendChild(optB);
        });

        // Default: first and last
        if (timeline.length >= 2) {
            selA.value = timeline[0].id;
            selB.value = timeline[timeline.length - 1].id;
        }
    }

    async function compareDiff() {
        var ip = document.getElementById('compareIp').value.trim();
        var snapA = document.getElementById('snapshotA').value;
        var snapB = document.getElementById('snapshotB').value;

        if (!ip || !snapA || !snapB) return;
        if (snapA === snapB) {
            showError('{{ t("compare.select_snapshots") }}');
            return;
        }

        hideError();
        document.getElementById('diffResults').style.display = 'none';
        document.getElementById('diffLoading').classList.remove('d-none');

        try {
            var url = rootPath + '/api/v1/results/' + encodeURIComponent(ip) +
                      '/compare?snapshot_a=' + snapA + '&snapshot_b=' + snapB;
            var resp = await fetch(url);
            if (!resp.ok) {
                var err = await resp.json().catch(function() { return {}; });
                showError(err.detail || 'Comparison failed');
                return;
            }

            var data = await resp.json();
            renderDiff(data);
            document.getElementById('diffResults').style.display = 'block';
        } catch (e) {
            showError(e.message);
        } finally {
            document.getElementById('diffLoading').classList.add('d-none');
        }
    }

    function renderDiff(data) {
        var diff = data.diff;

        // Score delta
        var deltaEl = document.getElementById('scoreDelta');
        var delta = diff.score_change;
        if (delta > 0) {
            deltaEl.innerHTML = '<span class="score-delta-up">+' + delta + ' &#x2191;</span>';
        } else if (delta < 0) {
            deltaEl.innerHTML = '<span class="score-delta-down">' + delta + ' &#x2193;</span>';
        } else {
            deltaEl.innerHTML = '<span class="score-delta-same">0 &#x2192;</span>';
        }

        // Level change
        var levelEl = document.getElementById('levelChange');
        var lc = diff.level_change;
        if (lc.changed) {
            levelEl.innerHTML =
                '<span class="badge ' + getLevelBadgeClass(lc.from) + ' me-2">' + lc.from + '</span>' +
                '<span class="text-muted">&rarr;</span> ' +
                '<span class="badge ' + getLevelBadgeClass(lc.to) + ' ms-2">' + lc.to + '</span>';
        } else {
            levelEl.innerHTML =
                '<span class="badge ' + getLevelBadgeClass(lc.from) + '">' + lc.from + '</span>' +
                ' <span class="text-muted">({{ t("compare.unchanged") }})</span>';
        }

        // Evidence diff table
        var tbody = document.getElementById('evidenceDiffBody');
        tbody.innerHTML = '';

        var ed = diff.evidence_diff;
        (ed.added || []).forEach(function(e) {
            tbody.innerHTML +=
                '<tr class="diff-added">' +
                '<td><span class="badge bg-success">{{ t("compare.evidence_added") }}</span></td>' +
                '<td>' + esc(e.source || '') + '</td>' +
                '<td>' + esc(e.title || '') + '</td>' +
                '<td>' + esc(e.severity || '') + '</td>' +
                '<td>' + (e.score_delta != null ? e.score_delta : '') + '</td>' +
                '</tr>';
        });

        (ed.removed || []).forEach(function(e) {
            tbody.innerHTML +=
                '<tr class="diff-removed">' +
                '<td><span class="badge bg-danger">{{ t("compare.evidence_removed") }}</span></td>' +
                '<td>' + esc(e.source || '') + '</td>' +
                '<td>' + esc(e.title || '') + '</td>' +
                '<td>' + esc(e.severity || '') + '</td>' +
                '<td>' + (e.score_delta != null ? e.score_delta : '') + '</td>' +
                '</tr>';
        });

        (ed.changed || []).forEach(function(c) {
            var from = c.from || {};
            var to = c.to || {};
            tbody.innerHTML +=
                '<tr class="diff-changed">' +
                '<td><span class="badge bg-warning text-dark">{{ t("compare.evidence_changed") }}</span></td>' +
                '<td>' + esc((c.key || '').split('::')[0]) + '</td>' +
                '<td>' + esc((c.key || '').split('::')[1] || '') + '</td>' +
                '<td>' + esc(from.severity || '') + ' &rarr; ' + esc(to.severity || '') + '</td>' +
                '<td>' + (from.score_delta != null ? from.score_delta : '') +
                ' &rarr; ' + (to.score_delta != null ? to.score_delta : '') + '</td>' +
                '</tr>';
        });

        if ((ed.added || []).length === 0 && (ed.removed || []).length === 0 && (ed.changed || []).length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted">{{ t("compare.unchanged") }}</td></tr>';
        }

        // Source diff
        var srcDiv = document.getElementById('sourceDiffContent');
        var sd = diff.source_diff || {};
        var srcKeys = Object.keys(sd);
        if (srcKeys.length === 0) {
            srcDiv.innerHTML = '<span class="text-muted">{{ t("compare.unchanged") }}</span>';
        } else {
            var html = '';
            srcKeys.forEach(function(src) {
                var status = sd[src].status;
                var cls = status === 'added' ? 'bg-success' : status === 'removed' ? 'bg-danger' : 'bg-warning text-dark';
                html += '<span class="badge ' + cls + ' me-2 mb-1">' + esc(src) + ': ' + status + '</span>';
            });
            srcDiv.innerHTML = html;
        }
    }

    function esc(str) {
        var div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }

    // Auto-load if IP is provided via query param
    document.addEventListener('DOMContentLoaded', function() {
        var ip = document.getElementById('compareIp').value.trim();
        if (ip) loadHistory();

        // Enter key triggers load
        document.getElementById('compareIp').addEventListener('keydown', function(e) {
            if (e.key === 'Enter') { e.preventDefault(); loadHistory(); }
        });
    });
    </script>
</body>
</html>
