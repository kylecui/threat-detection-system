-- ==================== 3. 威胁标签关联表 ====================

CREATE TABLE IF NOT EXISTS threat_assessment_labels (
    id SERIAL PRIMARY KEY,
    threat_assessment_id BIGINT NOT NULL,
    label_code VARCHAR(50) NOT NULL,
    confidence DECIMAL(5,2) DEFAULT 1.0,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (threat_assessment_id) REFERENCES threat_assessments(id) ON DELETE CASCADE
);

-- 创建索引
CREATE INDEX IF NOT EXISTS idx_assessment_labels_threat_id ON threat_assessment_labels(threat_assessment_id);
CREATE INDEX IF NOT EXISTS idx_assessment_labels_code ON threat_assessment_labels(label_code);

-- ==================== 4. 验证数据 ====================

-- 验证威胁标签
SELECT 
    COUNT(*) as total_labels,
    COUNT(DISTINCT category) as categories,
    COUNT(DISTINCT severity) as severities
FROM threat_labels;

-- 按分类统计标签
SELECT 
    category,
    COUNT(*) as label_count,
    string_agg(DISTINCT severity, ', ') as severities
FROM threat_labels
GROUP BY category
ORDER BY label_count DESC;

-- 验证白名单配置
SELECT 
    whitelist_type,
    COUNT(*) as count,
    COUNT(CASE WHEN is_active THEN 1 END) as active_count
FROM whitelist_config
GROUP BY whitelist_type;

-- ==================== 5. 表注释 ====================

COMMENT ON TABLE threat_labels IS '威胁标签配置表,定义各类威胁的标签和分类';
COMMENT ON TABLE whitelist_config IS '白名单配置表,用于过滤信任的IP/MAC/端口';
COMMENT ON TABLE threat_assessment_labels IS '威胁评估标签关联表,记录每次评估的标签';

COMMENT ON COLUMN threat_labels.label_code IS '标签代码(唯一标识)';
COMMENT ON COLUMN threat_labels.severity IS '严重程度: INFO/LOW/MEDIUM/HIGH/CRITICAL';
COMMENT ON COLUMN whitelist_config.whitelist_type IS '白名单类型: IP/MAC/PORT/COMBINED';
COMMENT ON COLUMN whitelist_config.expires_at IS '过期时间(NULL表示永久有效)';

