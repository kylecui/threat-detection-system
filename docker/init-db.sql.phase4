-- ==================== 2. 白名单配置表 ====================

CREATE TABLE IF NOT EXISTS whitelist_config (
    id SERIAL PRIMARY KEY,
    customer_id VARCHAR(50) NOT NULL,
    whitelist_type VARCHAR(20) NOT NULL,
    ip_address VARCHAR(45),
    mac_address VARCHAR(17),
    port_number INTEGER,
    reason TEXT,
    created_by VARCHAR(100),
    expires_at TIMESTAMP,
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 创建索引
CREATE INDEX IF NOT EXISTS idx_whitelist_customer ON whitelist_config(customer_id);
CREATE INDEX IF NOT EXISTS idx_whitelist_type ON whitelist_config(whitelist_type);
CREATE INDEX IF NOT EXISTS idx_whitelist_ip ON whitelist_config(ip_address);
CREATE INDEX IF NOT EXISTS idx_whitelist_mac ON whitelist_config(mac_address);
CREATE INDEX IF NOT EXISTS idx_whitelist_active ON whitelist_config(is_active);
CREATE INDEX IF NOT EXISTS idx_whitelist_expires ON whitelist_config(expires_at);

