-- Phase 2: 端口风险配置表
-- 执行: psql -U postgres -d threat_detection < init-db.sql.phase2

-- 1. 创建port_risk_config表
CREATE TABLE IF NOT EXISTS port_risk_config (
    id SERIAL PRIMARY KEY,
    port_number INTEGER NOT NULL UNIQUE,
    port_name VARCHAR(100) NOT NULL,
    risk_score DECIMAL(5,2) NOT NULL CHECK (risk_score >= 0.0 AND risk_score <= 5.0),
    category VARCHAR(50) NOT NULL,
    description TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    
    CONSTRAINT chk_port_range CHECK (port_number >= 1 AND port_number <= 65535)
);

-- 2. 创建索引
CREATE INDEX IF NOT EXISTS idx_port_number ON port_risk_config(port_number);
CREATE INDEX IF NOT EXISTS idx_category ON port_risk_config(category);
CREATE INDEX IF NOT EXISTS idx_risk_score ON port_risk_config(risk_score);

