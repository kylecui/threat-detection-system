-- 4. 验证插入结果
SELECT COUNT(*) as total_ports, 
       AVG(risk_score) as avg_risk_score,
       MAX(risk_score) as max_risk_score
FROM port_risk_config;

-- 5. 查看高危端口 (risk_score >= 2.5)
SELECT port_number, port_name, risk_score, category, description
FROM port_risk_config
WHERE risk_score >= 2.5
ORDER BY risk_score DESC;

COMMENT ON TABLE port_risk_config IS '端口风险配置表 - 存储219个常见端口的风险评分';
COMMENT ON COLUMN port_risk_config.port_number IS '端口号 (1-65535)';
COMMENT ON COLUMN port_risk_config.risk_score IS '风险评分 (0.0-5.0, 越高越危险)';
COMMENT ON COLUMN port_risk_config.category IS '端口分类 (REMOTE_ACCESS/DATABASE/WEB等)';
