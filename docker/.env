# Docker Compose Environment Configuration
# This file is automatically sourced by docker-compose

# Build parameters - prevents layer caching issues
# These are injected into all service builds
BUILD_DATE=$(date -u +'%Y-%m-%dT%H:%M:%SZ')

# Service versions (for tagging)
DATA_INGESTION_VERSION=1.0.0
STREAM_PROCESSING_VERSION=1.0.0
THREAT_ASSESSMENT_VERSION=1.0.0
ALERT_MANAGEMENT_VERSION=1.0.0
CUSTOMER_MANAGEMENT_VERSION=1.0.0
API_GATEWAY_VERSION=1.0.0

# Compose project name (affects container naming)
COMPOSE_PROJECT_NAME=threat-detection

# Enable BuildKit for better caching control
DOCKER_BUILDKIT=1

# For production, set to 0 to disable log buffering
BUILDKIT_PROGRESS=plain
