-- 4. 验证数据插入
SELECT 
    COUNT(*) as total_segments,
    COUNT(DISTINCT category) as categories,
    AVG(weight) as avg_weight,
    MIN(weight) as min_weight,
    MAX(weight) as max_weight
FROM ip_segment_weight_config;

-- 5. 按分类统计
SELECT 
    category,
    COUNT(*) as segment_count,
    AVG(weight) as avg_weight,
    MIN(weight) as min_weight,
    MAX(weight) as max_weight
FROM ip_segment_weight_config
GROUP BY category
ORDER BY avg_weight DESC;

-- 6. 查询高危网段 (权重 >= 1.7)
SELECT 
    segment_name,
    ip_range_start,
    ip_range_end,
    weight,
    category,
    description
FROM ip_segment_weight_config
WHERE weight >= 1.7
ORDER BY weight DESC, priority DESC;

-- 7. 添加表注释
COMMENT ON TABLE ip_segment_weight_config IS 'IP段权重配置表,用于基于源IP所属网段调整威胁评分';
COMMENT ON COLUMN ip_segment_weight_config.segment_name IS '网段名称';
COMMENT ON COLUMN ip_segment_weight_config.ip_range_start IS '网段起始IP';
COMMENT ON COLUMN ip_segment_weight_config.ip_range_end IS '网段结束IP';
COMMENT ON COLUMN ip_segment_weight_config.weight IS '权重系数 (0.5-2.0)';
COMMENT ON COLUMN ip_segment_weight_config.category IS '网段分类';
COMMENT ON COLUMN ip_segment_weight_config.priority IS '优先级 (用于IP匹配冲突时选择)';

